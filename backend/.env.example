# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  PETAL BACKEND — ENVIRONMENT VARIABLES                                       ║
# ║  Copy this file to .env and fill in all values before running locally.       ║
# ║  On Railway: set these as Environment Variables in the service dashboard.    ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas URI — get from Atlas > Connect > Drivers > Python (motor)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/petal_health?retryWrites=true&w=majority

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# REQUIRED in production — app will refuse to start without this on Railway.
# Generate a secure key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_64_char_random_hex_string

ALGORITHM=HS256

# Token expiry in minutes (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS & Redirect URIs ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
# In production, replace localhost values with your Vercel/Netlify URL.
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

# Must exactly match the redirect_uri values the frontend sends during Google OAuth.
# Used by both CORS validation and the Google OAuth callback handler.
ALLOWED_REDIRECT_URIS=https://your-frontend.vercel.app,http://localhost:5173

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Add your production frontend URL as an Authorized Redirect URI in Google Console.
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret

# ── Password Reset ────────────────────────────────────────────────────────────
# Base URL of your deployed frontend — appended to reset email magic links.
# Example: https://petal.vercel.app  (no trailing slash)
RESET_PASSWORD_BASE_URL=https://your-frontend.vercel.app
